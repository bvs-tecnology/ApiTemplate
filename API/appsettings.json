{
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Error",
        "System": "Error"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:30013"
        }
      }
    ]
  },
  "Keycloak": {
    "Audience": "account",
    "Issuer": "http://localhost:5430/auth/realms/template",
    "RealmId": "Template",
    "ClientId": "template"
  },
  "ElasticApm": {
    "ServiceName": "my-service-name",
    "SecretToken": "",
    "ServerUrl": "https://apm.bvsilva.com",
    "Environment": "my-environment"
  },
  "ConnectionStrings": {
    "Postgres": "Server=localhost;Port=5432;Database=bvstech_dev;User Id=dev_user;Password=6y+}eP[8#M9{;",
    "Redis": "localhost:6379"
  }
}
